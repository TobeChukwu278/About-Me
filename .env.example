# Environment Configuration Template
# Copy this to .env and update with your actual values

# MongoDB Connection URI
# Get this from MongoDB Atlas: https://cloud.mongodb.com/
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0

# Session Secret Key (use a strong random value in production)
# Generate: https://1password.com/password-generator/
SESSION_SECRET=your-super-secret-key-change-in-production-please

# Node Environment
NODE_ENV=development

# Port (Render will set this automatically)
PORT=3000
