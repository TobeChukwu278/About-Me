<!-- System Status Indicator -->
<div class="fixed top-24 right-4 z-30 flex items-center gap-2 bg-gray-800/80 backdrop-blur-sm px-4 py-2 rounded-full border border-emerald-500/30">
  <div class="status-indicator" id="statusIndicator"></div>
  <span class="text-xs text-emerald-400 font-semibold" id="statusText">CHECKING...</span>
</div>

<!-- CLI-Inspired Navbar -->
<nav class="border-b border-gray-800 bg-gray-900/50 backdrop-blur-sm sticky top-0 z-40">
  <div class="max-w-7xl mx-auto px-6 py-4">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <span class="text-sm text-cyan-400">tobe@backend:~$</span>
        <span class="text-gray-500 ml-2 text-sm">portfolio --mode=showcase</span>
      </div>
      <div class="flex items-center gap-4">
        <button id="chatToggle" class="flex items-center gap-2 px-3 py-1.5 bg-violet-500/10 border border-violet-500/30 rounded-md hover:bg-violet-500/20 transition-all">
          <svg class="w-4 h-4 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          <span class="text-xs text-violet-400">Portfolio Assistant</span>
        </button>
      </div>
    </div>
  </div>
</nav>

<!-- AI Chat Panel -->
<div id="chatPanel" class="hidden fixed right-6 top-20 w-96 h-[500px] bg-gray-900 border border-cyan-500/30 rounded-lg shadow-2xl z-50 flex flex-col">
  <div class="bg-gradient-to-r from-cyan-500/20 to-violet-500/20 px-4 py-3 border-b border-gray-800 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <svg class="w-4 h-4 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
      </svg>
      <span class="text-sm font-semibold text-cyan-400">Portfolio Assistant</span>
    </div>
    <button id="chatClose" class="text-gray-400 hover:text-gray-200">✕</button>
  </div>
  
  <div id="chatMessages" class="flex-1 overflow-y-auto p-4 space-y-3">
    <div class="text-gray-500 text-sm">
      <p class="mb-2">👋 Hi! I can help you learn about:</p>
      <ul class="space-y-1 ml-4">
        <li>• Tech stack & technologies</li>
        <li>• Projects & experience</li>
        <li>• Skills & expertise</li>
      </ul>
    </div>
  </div>
  
  <div class="border-t border-gray-800 p-3">
    <div class="flex gap-2">
      <input
        type="text"
        id="chatInput"
        placeholder="Ask about tech stack, projects..."
        class="flex-1 bg-gray-800 border border-gray-700 rounded px-3 py-2 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:border-cyan-500/50"
      />
      <button
        id="chatSend"
        class="px-4 py-2 bg-cyan-500/20 border border-cyan-500/30 rounded text-cyan-400 hover:bg-cyan-500/30 transition-all text-sm"
      >
        Send
      </button>
    </div>
  </div>
</div>

<!-- Main Content -->
<div class="max-w-7xl mx-auto px-6 py-12">
  <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-4 auto-rows-auto">
    
    <!-- Hero Section -->
    <div class="bento-card md:col-span-2 lg:col-span-2 md:row-span-2 bg-gradient-to-br from-gray-800/50 to-gray-900/50 backdrop-blur-sm border border-cyan-500/20 rounded-2xl p-8 hover-glow transition-all overflow-hidden relative">
      <div class="absolute inset-0 opacity-5">
        <div class="absolute inset-0" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,255,255,0.1) 2px, rgba(0,255,255,0.1) 4px); background-size: 100% 4px;"></div>
      </div>
      <div class="relative z-10">
        <h1 class="text-4xl md:text-5xl font-bold mb-2 bg-gradient-to-r from-cyan-400 via-emerald-400 to-violet-400 bg-clip-text text-transparent">
          <%= hero.name || 'TOBE EJIOFOR' %>
        </h1>
        <div class="flex items-center gap-2 mb-6 text-gray-400">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
          </svg>
          <span class="text-xl"><%= hero.title || 'Web Dev' %></span>
        </div>
        <p class="text-emerald-400 text-sm mb-6 flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          <%= hero.techStack ? hero.techStack.join(' • ') : 'Fastify • Node.js • MongoDB • Express' %>
        </p>
        <p class="text-gray-300 mb-8 leading-relaxed">
          <%= hero.tagline || 'Building scalable APIs and robust backend systems with precision and performance' %>
        </p>
        <button class="px-6 py-3 bg-gradient-to-r from-cyan-500/20 to-emerald-500/20 border border-cyan-500/50 rounded-lg text-cyan-400 hover:bg-cyan-500/30 transition-all font-semibold flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
          </svg>
          View My Work
        </button>
      </div>
    </div>

    <!-- Backend Stack -->
    <div class="bento-card md:col-span-1 lg:col-span-2 bg-gray-800/50 backdrop-blur-sm border border-emerald-500/20 rounded-2xl p-6 hover-glow transition-all">
      <h3 class="text-lg font-semibold mb-4 text-emerald-400 flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
        </svg>
        Backend Stack
      </h3>
      <div class="space-y-3">
        <% if (techStack && techStack.length > 0) { %>
          <% techStack.slice(0, 3).forEach(tech => { %>
            <div class="bg-gray-900/50 border border-gray-700 rounded-lg p-3 hover:border-emerald-500/50 transition-all cursor-pointer group">
              <div class="flex items-center gap-3">
                <span class="text-2xl"><%= tech.icon %></span>
                <div class="flex-1">
                  <div class="font-semibold text-sm text-gray-200 group-hover:text-emerald-400 transition-colors"><%= tech.name %></div>
                  <div class="text-xs text-gray-500"><%= tech.description %></div>
                </div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <!-- Live Stats -->
    <div class="bento-card md:col-span-2 lg:col-span-2 bg-gray-800/50 backdrop-blur-sm border border-violet-500/20 rounded-2xl p-6 hover-glow transition-all">
      <h3 class="text-lg font-semibold mb-4 text-violet-400 flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
        </svg>
        Live System Stats
      </h3>
      <div class="grid grid-cols-3 gap-4">
        <div class="bg-gradient-to-br from-emerald-500/10 to-transparent border border-emerald-500/30 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-emerald-400 mb-1" id="uptime">--</div>
          <div class="text-xs text-gray-400">API Uptime</div>
        </div>
        <div class="bg-gradient-to-br from-cyan-500/10 to-transparent border border-cyan-500/30 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-cyan-400 mb-1" id="latency">--</div>
          <div class="text-xs text-gray-400">Avg Latency</div>
        </div>
        <div class="bg-gradient-to-br from-violet-500/10 to-transparent border border-violet-500/30 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-violet-400 mb-1" id="requests">--</div>
          <div class="text-xs text-gray-400">Requests Served</div>
        </div>
      </div>
    </div>

    <!-- Projects -->
    <div class="bento-card md:col-span-2 lg:col-span-2 md:row-span-2 bg-gray-800/50 backdrop-blur-sm border border-cyan-500/20 rounded-2xl p-6 hover-glow transition-all">
      <h3 class="text-lg font-semibold mb-4 text-cyan-400 flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
        </svg>
        Featured Projects
      </h3>
      <div class="space-y-4">
        <% if (projects && projects.length > 0) { %>
          <% projects.forEach(project => { %>
            <div class="bg-gray-900/50 border border-gray-700 rounded-lg p-4 hover:border-cyan-500/50 hover:transform hover:scale-[1.02] transition-all cursor-pointer group">
              <h4 class="font-semibold text-gray-200 mb-2 group-hover:text-cyan-400 transition-colors"><%= project.name %></h4>
              <p class="text-sm text-gray-400 mb-3"><%= project.description %></p>
              <div class="flex flex-wrap gap-2">
                <% project.tags.forEach(tag => { %>
                  <span class="px-2 py-1 bg-cyan-500/10 border border-cyan-500/30 rounded text-xs text-cyan-400">
                    <%= tag %>
                  </span>
                <% }) %>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <!-- Experience -->
    <div class="bento-card md:col-span-1 lg:col-span-2 md:row-span-2 bg-gray-800/50 backdrop-blur-sm border border-emerald-500/20 rounded-2xl p-6 hover-glow transition-all">
      <h3 class="text-lg font-semibold mb-4 text-emerald-400 flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
        </svg>
        Experience
      </h3>
      <div class="space-y-4">
        <% if (experience && experience.length > 0) { %>
          <% experience.forEach(exp => { %>
            <div class="border-l-2 border-emerald-500/50 pl-4 py-2 hover:border-emerald-400 transition-all">
              <div class="font-semibold text-gray-200"><%= exp.role %></div>
              <div class="text-sm text-emerald-400"><%= exp.company %></div>
              <div class="text-xs text-gray-500 mt-1"><%= exp.period %></div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <!-- About -->
    <div class="bento-card md:col-span-2 lg:col-span-2 bg-gray-800/50 backdrop-blur-sm border border-violet-500/20 rounded-2xl p-6 hover-glow transition-all relative overflow-hidden">
      <div class="absolute right-4 bottom-4 text-6xl opacity-5">⚡</div>
      <h3 class="text-lg font-semibold mb-4 text-violet-400">About</h3>
      <p class="text-gray-300 leading-relaxed relative z-10">
        <%= about.text || 'Passionate about crafting efficient, maintainable backend systems.' %>
      </p>
    </div>

    <!-- Contact -->
    <div class="bento-card md:col-span-3 lg:col-span-4 bg-gradient-to-r from-gray-800/50 to-gray-900/50 backdrop-blur-sm border border-cyan-500/20 rounded-2xl p-6 hover-glow transition-all">
      <h3 class="text-lg font-semibold mb-4 text-cyan-400 flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        Connect
      </h3>
      <div class="flex flex-col md:flex-row gap-4 items-center">
        <div class="flex-1 bg-gray-900/50 border border-gray-700 rounded-lg px-4 py-3 font-mono text-sm text-gray-400 flex items-center">
          <span class="text-emerald-400 mr-2">></span>
          <span class="terminal-cursor">connect --with <%= contact.email || 'tobe@backend.dev' %></span>
        </div>
        <div class="flex gap-3">
          <% if (contact.github) { %>
            <a href="<%= contact.github %>" target="_blank" class="px-4 py-2 bg-gray-900/50 border border-gray-700 rounded-lg hover:border-cyan-500/50 transition-all flex items-center gap-2 text-gray-400 hover:text-cyan-400">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              <span class="text-sm">GitHub</span>
            </a>
          <% } %>
          <% if (contact.linkedin) { %>
            <a href="<%= contact.linkedin %>" target="_blank" class="px-4 py-2 bg-gray-900/50 border border-gray-700 rounded-lg hover:border-cyan-500/50 transition-all flex items-center gap-2 text-gray-400 hover:text-cyan-400">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              <span class="text-sm">LinkedIn</span>
            </a>
          <% } %>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Footer -->
<footer class="border-t border-gray-800 bg-gray-900/50 backdrop-blur-sm mt-12">
  <div class="max-w-7xl mx-auto px-6 py-6 text-center text-sm text-gray-500">
    Made with <span class="text-emerald-400">⚡ Fastify</span> & <span class="text-emerald-400">MongoDB</span> | © 20241 Tobe Ejiofor
  </div>
</footer>
