<style>
    .demo-container {
        position: relative;
        width: 100%;
        padding-bottom: 56.25%;
        /* 16:9 aspect ratio */
        height: 0;
        overflow: hidden;
        border-radius: 0.5rem;
        border: 1px solid rgba(34, 197, 94, 0.3);
    }

    .demo-container iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }

    .project-header {
        background: linear-gradient(135deg, rgba(6, 182, 212, 0.1) 0%, rgba(139, 92, 246, 0.1) 100%);
        border-bottom: 1px solid rgba(34, 197, 94, 0.2);
    }

    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        color: #9ca3af;
    }

    .breadcrumb a {
        color: #06b6d4;
        text-decoration: none;
        transition: color 0.2s;
    }

    .breadcrumb a:hover {
        color: #10b981;
    }

    .section-divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(34, 197, 94, 0.2), transparent);
        margin: 2rem 0;
    }
</style>

<!-- CLI-Inspired Navbar -->
<nav class="border-b border-gray-800 bg-gray-900/50 backdrop-blur-sm sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-6 py-4">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <span class="text-sm text-cyan-400">tobe@backend:~$</span>
                <span class="text-gray-500 ml-2 text-sm">portfolio --mode=project</span>
            </div>
            <a href="/"
                class="px-3 py-1.5 bg-violet-500/10 border border-violet-500/30 rounded-md hover:bg-violet-500/20 transition-all text-xs text-violet-400">
                ← Back to Portfolio
            </a>
        </div>
    </div>
</nav>

<!-- Project Header -->
<div class="project-header py-12 border-b border-gray-800">
    <div class="max-w-6xl mx-auto px-6">
        <!-- Breadcrumb -->
        <div class="breadcrumb mb-6">
            <a href="/">Portfolio</a>
            <span>/</span>
            <span class="text-gray-400">Projects</span>
            <span>/</span>
            <span class="text-emerald-400">
                <%= project.name %>
            </span>
        </div>

        <h1
            class="text-5xl font-bold mb-4 bg-gradient-to-r from-cyan-400 via-emerald-400 to-violet-400 bg-clip-text text-transparent">
            <%= project.name %>
        </h1>

        <p class="text-lg text-gray-300 mb-6 max-w-3xl">
            <%= project.description %>
        </p>

        <div class="flex flex-wrap gap-3 mb-6">
            <% if (project.tags && project.tags.length> 0) { %>
                <% project.tags.forEach(tag=> { %>
                    <span class="px-3 py-1 bg-cyan-500/10 border border-cyan-500/30 rounded-full text-sm text-cyan-400">
                        <%= tag %>
                    </span>
                    <% }); %>
                        <% } %>
        </div>

        <div class="flex flex-wrap gap-4">
            <% if (project.liveUrl) { %>
                <a href="<%= project.liveUrl %>" target="_blank" rel="noopener noreferrer"
                    class="px-6 py-3 bg-gradient-to-r from-emerald-500/20 to-emerald-600/20 border border-emerald-500/50 rounded-lg text-emerald-400 hover:bg-emerald-500/30 transition-all font-semibold flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                    View Live Project
                </a>
                <% } %>
                    <% if (project.githubUrl) { %>
                        <a href="<%= project.githubUrl %>" target="_blank" rel="noopener noreferrer"
                            class="px-6 py-3 bg-gray-800/50 border border-gray-700 rounded-lg text-gray-300 hover:border-cyan-500/50 transition-all font-semibold flex items-center gap-2">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                                <path
                                    d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                            </svg>
                            View Source
                        </a>
                        <% } %>
        </div>
    </div>
</div>

<!-- Main Content -->
<div class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Content Area -->
        <div class="lg:col-span-2">
            <!-- Project Overview -->
            <section class="mb-12">
                <h2 class="text-3xl font-semibold mb-6 text-cyan-400 flex items-center gap-2">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Project Overview
                </h2>
                <p class="text-gray-300 leading-relaxed text-lg">
                    <%= project.longDescription || project.description %>
                </p>
            </section>

            <div class="section-divider"></div>

            <!-- Live Demo -->
            <% if (project.liveDemo) { %>
                <section class="mb-12">
                    <h2 class="text-3xl font-semibold mb-6 text-emerald-400 flex items-center gap-2">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M14.828 14.828a4 4 0 01-5.656 0M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        Live Demo
                    </h2>
                    <div class="bg-gray-900/50 border border-gray-800 rounded-lg p-4 overflow-hidden">
                        <div class="demo-container">
                            <iframe src="<%= project.liveDemo %>" title="<%= project.name %> Demo" frameborder="0"
                                allow="accelerometer; ambient-light-sensor; camera; encrypted-media; geolocation; gyroscope; picture-in-picture"
                                allowfullscreen>
                            </iframe>
                        </div>
                    </div>
                    <p class="text-gray-400 text-sm mt-4">
                        The demo above is an interactive preview of the project. You can interact with it directly or
                        visit the live project link at the top to see the full application.
                    </p>
                </section>

                <div class="section-divider"></div>
                <% } %>

                    <!-- Technical Details -->
                    <section>
                        <h2 class="text-3xl font-semibold mb-6 text-violet-400 flex items-center gap-2">
                            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                            </svg>
                            Technologies Used
                        </h2>
                        <% if (project.tags && project.tags.length> 0) { %>
                            <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                                <% project.tags.forEach(tag=> { %>
                                    <div
                                        class="bg-gray-800/50 border border-gray-700 rounded-lg p-4 hover:border-cyan-500/50 transition-all">
                                        <div class="font-semibold text-gray-200 text-center">
                                            <%= tag %>
                                        </div>
                                    </div>
                                    <% }); %>
                            </div>
                            <% } %>
                    </section>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1">
            <!-- Quick Links -->
            <div class="sticky top-20 space-y-4">
                <div class="bg-gradient-to-br from-gray-800/50 to-gray-900/50 border border-cyan-500/20 rounded-lg p-6">
                    <h3 class="text-lg font-semibold text-cyan-400 mb-4 flex items-center gap-2">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.658 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                        </svg>
                        Quick Links
                    </h3>
                    <div class="space-y-3">
                        <% if (project.liveUrl) { %>
                            <a href="<%= project.liveUrl %>" target="_blank" rel="noopener noreferrer"
                                class="block w-full px-4 py-2 bg-emerald-500/10 border border-emerald-500/30 rounded text-emerald-400 hover:bg-emerald-500/20 transition-all text-center text-sm font-medium">
                                🌍 Live Project
                            </a>
                            <% } %>
                                <% if (project.githubUrl) { %>
                                    <a href="<%= project.githubUrl %>" target="_blank" rel="noopener noreferrer"
                                        class="block w-full px-4 py-2 bg-gray-700/30 border border-gray-600/50 rounded text-gray-300 hover:bg-gray-700/50 transition-all text-center text-sm font-medium">
                                        💻 View Source
                                    </a>
                                    <% } %>
                                        <a href="/"
                                            class="block w-full px-4 py-2 bg-violet-500/10 border border-violet-500/30 rounded text-violet-400 hover:bg-violet-500/20 transition-all text-center text-sm font-medium">
                                            ← Back Home
                                        </a>
                    </div>
                </div>

                <!-- Project Stats -->
                <div
                    class="bg-gradient-to-br from-gray-800/50 to-gray-900/50 border border-violet-500/20 rounded-lg p-6">
                    <h3 class="text-lg font-semibold text-violet-400 mb-4 flex items-center gap-2">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                        </svg>
                        Project Info
                    </h3>
                    <div class="space-y-4 text-sm">
                        <div>
                            <div class="text-gray-500 mb-1">Status</div>
                            <div
                                class="px-3 py-1 bg-emerald-500/20 border border-emerald-500/30 rounded text-emerald-400 inline-block">
                                Active
                            </div>
                        </div>
                        <div>
                            <div class="text-gray-500 mb-2">Featured</div>
                            <div class="flex items-center gap-2 text-yellow-400">
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                    <path
                                        d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                </svg>
                                Featured Project
                            </div>
                        </div>
                        <div>
                            <div class="text-gray-500 mb-1">Created</div>
                            <div class="text-gray-300">
                                <%= new Date(project.createdAt).toLocaleDateString('en-US', { year: 'numeric' ,
                                    month: 'long' , day: 'numeric' }) %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Footer -->
<footer class="border-t border-gray-800 bg-gray-900/50 backdrop-blur-sm mt-12">
    <div class="max-w-7xl mx-auto px-6 py-6 text-center text-sm text-gray-500">
        Made with <span class="text-emerald-400">⚡ Fastify</span> & <span class="text-emerald-400">MongoDB</span> | ©
        2024
        Tobe Ejiofor
    </div>
</footer>