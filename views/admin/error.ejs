<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Error</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-900 text-gray-100 min-h-screen flex items-center justify-center">
    <div class="max-w-lg w-full p-6">
        <div class="bg-gray-800 border border-red-500/20 rounded-lg p-6 text-center">
            <h1 class="text-2xl font-bold text-red-400 mb-2">Something went wrong</h1>
            <p class="text-gray-400 mb-4">
                <%= error || 'An unexpected error occurred.' %>
            </p>
            <a href="/admin/dashboard"
                class="px-4 py-2 bg-red-500/10 border border-red-500/30 rounded text-red-300">Back to Dashboard</a>
        </div>
    </div>
</body>

</html>