<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= pageTitle %>
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-900 text-gray-100 min-h-screen">
    <nav class="bg-gray-800 border-b border-gray-700">
        <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
            <div class="flex items-center gap-4">
                <h1 class="text-lg font-bold text-orange-400">⚡ Admin - Edit Experience</h1>
                <a href="/admin/experience" class="text-sm text-gray-400 hover:text-cyan-400">Back</a>
            </div>
            <a href="/admin/logout" class="text-sm text-red-400">Logout</a>
        </div>
    </nav>

    <main class="max-w-4xl mx-auto p-6">
        <div class="bg-gray-800 border border-gray-700 rounded-lg p-6">
            <h2 class="text-xl font-semibold text-amber-400 mb-4">Edit Experience - <%= experience.role %>
            </h2>
            <form method="POST" action="/admin/experience/edit/<%= experience._id %>" class="space-y-4">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <div>
                    <label class="block text-sm text-gray-300 mb-1">Role</label>
                    <input type="text" name="role" value="<%= experience.role %>" required
                        class="w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded text-gray-200" />
                </div>
                <div>
                    <label class="block text-sm text-gray-300 mb-1">Company</label>
                    <input type="text" name="company" value="<%= experience.company %>" required
                        class="w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded text-gray-200" />
                </div>
                <div>
                    <label class="block text-sm text-gray-300 mb-1">Period</label>
                    <input type="text" name="period" value="<%= experience.period %>"
                        class="w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded text-gray-200" />
                </div>
                <div>
                    <label class="block text-sm text-gray-300 mb-1">Description</label>
                    <textarea name="description"
                        class="w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded text-gray-200"><%= experience.description %></textarea>
                </div>
                <div>
                    <label class="block text-sm text-gray-300 mb-1">Order</label>
                    <input type="number" name="order" value="<%= experience.order || 0 %>"
                        class="w-24 px-3 py-2 bg-gray-900 border border-gray-700 rounded text-gray-200" />
                </div>
                <div>
                    <button class="px-4 py-2 bg-amber-500/20 border border-amber-500/40 rounded text-amber-300">Save
                        Changes</button>
                    <a href="/admin/experience" class="ml-3 text-sm text-gray-400">Cancel</a>
                </div>
            </form>
        </div>
    </main>
</body>

</html>