<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: 'JetBrains Mono', monospace; }
  </style>
</head>
<body class="bg-gray-900 text-gray-100">
  
  <!-- Admin Navbar -->
  <nav class="bg-gray-800 border-b border-gray-700">
    <div class="max-w-7xl mx-auto px-6 py-4">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-4">
          <h1 class="text-xl font-bold text-cyan-400">⚡ Admin Dashboard</h1>
          <div class="flex gap-2 text-sm">
            <a href="/admin/dashboard" class="px-3 py-1.5 bg-cyan-500/20 text-cyan-400 rounded">Dashboard</a>
            <a href="/admin/hero" class="px-3 py-1.5 text-gray-400 hover:text-gray-200">Hero</a>
            <a href="/admin/tech-stack" class="px-3 py-1.5 text-gray-400 hover:text-gray-200">Tech Stack</a>
            <a href="/admin/projects" class="px-3 py-1.5 text-gray-400 hover:text-gray-200">Projects</a>
            <a href="/admin/analytics" class="px-3 py-1.5 text-gray-400 hover:text-gray-200">Analytics</a>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <span class="text-sm text-gray-400">Welcome, <span class="text-emerald-400"><%= username %></span></span>
          <a href="/admin/logout" class="px-3 py-1.5 bg-red-500/20 text-red-400 rounded text-sm hover:bg-red-500/30">Logout</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <div class="max-w-7xl mx-auto px-6 py-8">
    
    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      
      <div class="bg-gray-800 border border-cyan-500/30 rounded-lg p-6">
        <div class="flex items-center justify-between mb-2">
          <h3 class="text-sm text-gray-400">Hero Section</h3>
          <svg class="w-5 h-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>
        <div class="text-3xl font-bold text-cyan-400"><%= stats.heroCount %></div>
        <a href="/admin/hero" class="text-xs text-gray-500 hover:text-cyan-400">Manage →</a>
      </div>

      <div class="bg-gray-800 border border-emerald-500/30 rounded-lg p-6">
        <div class="flex items-center justify-between mb-2">
          <h3 class="text-sm text-gray-400">Tech Stack</h3>
          <svg class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
          </svg>
        </div>
        <div class="text-3xl font-bold text-emerald-400"><%= stats.techStackCount %></div>
        <a href="/admin/tech-stack" class="text-xs text-gray-500 hover:text-emerald-400">Manage →</a>
      </div>

      <div class="bg-gray-800 border border-violet-500/30 rounded-lg p-6">
        <div class="flex items-center justify-between mb-2">
          <h3 class="text-sm text-gray-400">Projects</h3>
          <svg class="w-5 h-5 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
          </svg>
        </div>
        <div class="text-3xl font-bold text-violet-400"><%= stats.projectCount %></div>
        <a href="/admin/projects" class="text-xs text-gray-500 hover:text-violet-400">Manage →</a>
      </div>

      <div class="bg-gray-800 border border-orange-500/30 rounded-lg p-6">
        <div class="flex items-center justify-between mb-2">
          <h3 class="text-sm text-gray-400">Experience</h3>
          <svg class="w-5 h-5 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <div class="text-3xl font-bold text-orange-400"><%= stats.experienceCount %></div>
        <a href="/admin/experience" class="text-xs text-gray-500 hover:text-orange-400">Manage →</a>
      </div>

    </div>

    <!-- Analytics Overview -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
      
      <div class="bg-gray-800 border border-gray-700 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-gray-200 mb-4">Traffic Overview</h3>
        <div class="space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-400">Page Views</span>
            <span class="text-xl font-bold text-cyan-400"><%= stats.pageViews %></span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-400">Errors</span>
            <span class="text-xl font-bold text-red-400"><%= stats.errors %></span>
          </div>
        </div>
      </div>

      <div class="bg-gray-800 border border-gray-700 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-gray-200 mb-4">Quick Actions</h3>
        <div class="space-y-2">
          <a href="/admin/hero" class="block px-4 py-2 bg-cyan-500/10 border border-cyan-500/30 rounded text-cyan-400 hover:bg-cyan-500/20 transition-all text-sm">
            Edit Hero Section
          </a>
          <a href="/admin/projects" class="block px-4 py-2 bg-emerald-500/10 border border-emerald-500/30 rounded text-emerald-400 hover:bg-emerald-500/20 transition-all text-sm">
            Add New Project
          </a>
          <a href="/admin/analytics" class="block px-4 py-2 bg-violet-500/10 border border-violet-500/30 rounded text-violet-400 hover:bg-violet-500/20 transition-all text-sm">
            View Analytics
          </a>
        </div>
      </div>

    </div>

    <!-- Recent Activity -->
    <div class="bg-gray-800 border border-gray-700 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-gray-200 mb-4">Recent Activity</h3>
      <div class="space-y-2">
        <% if (recentAnalytics && recentAnalytics.length > 0) { %>
          <% recentAnalytics.forEach(log => { %>
            <div class="flex items-center justify-between py-2 border-b border-gray-700 last:border-0">
              <div>
                <span class="text-sm text-gray-300">
                  <span class="px-2 py-0.5 bg-gray-700 rounded text-xs <%= log.eventType === 'error' ? 'text-red-400' : 'text-cyan-400' %>">
                    <%= log.eventType %>
                  </span>
                  <%= log.page || 'Unknown' %>
                </span>
              </div>
              <span class="text-xs text-gray-500">
                <%= new Date(log.timestamp).toLocaleString() %>
              </span>
            </div>
          <% }) %>
        <% } else { %>
          <p class="text-sm text-gray-500">No recent activity</p>
        <% } %>
      </div>
    </div>

  </div>

</body>
</html>

