  <style>
    body {
  font-family: 'JetBrains Mono', monospace;
}

@keyframes shimmer {
  100% { transform: translateX(100%); }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse-glow {
  0%, 100% { 
    box-shadow: 0 0 20px rgba(0, 255, 255, 0.3);
    transform: translateY(0) scale(1);
  }
  50% { 
    box-shadow: 0 0 30px rgba(0, 255, 255, 0.6);
    transform: translateY(0) scale(1);
  }
}

@keyframes blink {
  0%, 49% { opacity: 1; }
  50%, 100% { opacity: 0; }
}

.skeleton-shimmer {
  position: relative;
  overflow: hidden;
  background: rgba(31, 41, 55, 0.5);
  border-radius: 0.25rem;
}

.skeleton-shimmer::after {
  content: '';
  position: absolute;
  inset: 0;
  transform: translateX(-100%);
  background: linear-gradient(90deg, transparent, rgba(107, 114, 128, 0.5), transparent);
  animation: shimmer 2s infinite;
}

.bento-card {
  animation: fadeInUp 0.6s ease-out forwards;
  opacity: 0;
  /* Ensure transform is preserved */
  transform-origin: center;
}

.bento-card:nth-child(1) { animation-delay: 0.1s; }
.bento-card:nth-child(2) { animation-delay: 0.2s; }
.bento-card:nth-child(3) { animation-delay: 0.3s; }
.bento-card:nth-child(4) { animation-delay: 0.4s; }
.bento-card:nth-child(5) { animation-delay: 0.5s; }
.bento-card:nth-child(6) { animation-delay: 0.6s; }
.bento-card:nth-child(7) { animation-delay: 0.7s; }

/* FIX: Add initial state and smooth transition */
.hover-glow {
  transition: box-shadow 0.3s ease, transform 0.3s ease;
  box-shadow: 0 0 0 rgba(0, 255, 255, 0);
  /* Prevent animation from resetting position */
  animation-fill-mode: forwards;
}

/*.hover-glow:hover {*/
  /*animation: pulse-glow 2s infinite;*/
  /* Maintain position during hover */
  /*animation-fill-mode: forwards;*/
/*}*/

.terminal-cursor::after {
  content: '▊';
  animation: blink 1s infinite;
}

.status-indicator {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #10b981;
  box-shadow: 0 0 10px #10b981;
  animation: pulse 2s infinite;
}

.status-indicator.offline {
  background: #ef4444;
  box-shadow: 0 0 10px #ef4444;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}
